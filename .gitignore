# AkanshaLive Project - Root Gitignore

# Dependencies
node_modules/
.pnp/
.pnp.*

# Environment and local secrets
.env
.env.*
!.env.example

# Next.js / React / production output
.next/
out/
dist/
build/
.turbo/

# Logs and diagnostics
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dev-server.log
frontend-dev.log

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/

# Test and coverage output
coverage/
test-results/
playwright-report/
.playwright/

# OS-specific files
.DS_Store
Thumbs.db
desktop.ini

# Deployment / tooling
.vercel/

# TypeScript
*.tsbuildinfo

# IDEs
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Databases and local storage
*.db
*.sqlite
*.sqlite3

# Generated project artifacts
graphify-out/
tmp_*/
aura/tmp_voice_recording_frames/
aura/codechef-login.html
aura/tmp-chat.html
aura/debug_prompt.txt

# Agent logs
.agent/
.codex/
